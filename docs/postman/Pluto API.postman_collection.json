    {
      "name": "Admin Auth",
      "item": [
        {
          "name": "List Adopters",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/admin/auth/adopter/list/",
            "description": "Requires admin access."
          }
        },
        {
          "name": "List Admin Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/admin/auth/admin-users/",
            "description": "Requires superadmin."
          }
        },
        {
          "name": "Update Admin User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"job_title\": \"Operations Admin\",\n  \"permissions\": [\n    {\n      \"module\": \"PET_LISTING_MANAGEMENT\",\n      \"actions\": [\"VIEW\", \"UPDATE\"]\n    },\n    {\n      \"module\": \"ADOPTION_MANAGEMENT\",\n      \"actions\": [\"VIEW\", \"UPDATE\"]\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/admin/auth/admin-users/{{adminId}}/"
          }
        },
        {
          "name": "Delete Admin User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/v1/admin/auth/admin-users/{{adminId}}/"
          }
        },
        {
          "name": "Send Admin Invitation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ops-admin@example.com\",\n  \"job_title\": \"Operations Admin\",\n  \"permissions\": [\n    {\n      \"module\": \"USER_MANAGEMENT\",\n      \"actions\": [\"VIEW\"]\n    },\n    {\n      \"module\": \"PET_LISTING_MANAGEMENT\",\n      \"actions\": [\"VIEW\", \"UPDATE\"]\n    }\n  ],\n  \"expires_in_hours\": 48\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/admin/auth/send-invitation/"
          }
        },
        {
          "name": "Verify Admin Invitation",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/admin/auth/verify-invitation/?token={{inviteToken}}"
          }
        },
        {
          "name": "Admin Register From Invitation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  if (json.data.access_token) pm.environment.set('accessToken', json.data.access_token);",
                  "  if (json.data.refresh_token) pm.environment.set('refreshToken', json.data.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{inviteToken}}\",\n  \"name\": \"Invited Admin\",\n  \"phone\": \"+15550003333\",\n  \"password\": \"password123\",\n  \"confirm_password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/admin/auth/admin-register/"
          }
        }
      ]
    },
