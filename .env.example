# Application
APP_ENV=dev
APP_SECRET=
DEBUG=true
TIME_ZONE=UTC

# Django hosts / CORS
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:9065,http://127.0.0.1:9065,http://localhost:9080,http://127.0.0.1:9080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
DB_NAME=pluto_db
DB_USER=pluto_db_owner
DB_PASSWORD=pluto_db_password
DB_HOST=localhost
DB_PORT=5545
DB_SSL_REQUIRE=false

# Email / SMTP
EMAIL_USE_TLS=true
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@pluto.local

# Celery / Redis / Channels
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CHANNELS_REDIS_URL=redis://localhost:6379/0
CELERY_TIMEZONE=UTC

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=

# Frontend URLs
USER_FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5173
ADMIN_INVITATION_PATH=/admin/register
ADMIN_INVITATION_EXPIRY_HOURS=48

# Docker Compose overrides
WSGI_PORT=9065
ASGI_PORT=9066
POSTGRES_FORWARD_PORT=5545
REDIS_FORWARD_PORT=6485
PROD_WSGI_PORT=9080
PROD_ASGI_PORT=9081
GUNICORN_WORKERS=3
UVICORN_WORKERS=2
